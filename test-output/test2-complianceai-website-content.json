); gap: 32px; }\n    .feature-card { padding: 32px; border: 1px solid #eee; border-radius: var(--radius); text-align: center; transition: box-shadow 0.2s; }\n    .feature-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); }\n    .feature-icon { font-size: 2rem; margin-bottom: 16px; color: var(--primary); }\n    .feature-card h3 { font-size: 1.1rem; margin-bottom: 8px; }\n    footer { padding: 32px 0; text-align: center; background: var(--primary); color: white; opacity: 0.9; }\n    @media (max-width: 768px) {\n      .hero h1 { font-size: 2rem; }\n      .hero p { font-size: 1rem; }\n      .features-grid { grid-template-columns: 1fr; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div class=\"container\">\n      <nav>\n        <div class=\"logo\">ComplianceAI</div>\n      </nav>\n    </div>\n  </header>\n  <main>\n    <section class=\"hero\">\n      <div class=\"container\">\n        <h1>Streamline Regulatory Compliance with AI</h1>\n        <p>Automate monitoring, reporting, and risk management for financial institutions</p>\n        <a href=\"#features\" class=\"cta-btn\">Learn More</a>\n      </div>\n    </section>\n    <section class=\"features\" id=\"features\">\n      <div class=\"container\">\n        <h2>Key Features</h2>\n        <div class=\"features-grid\">\n          \n      <div class=\"feature-card\">\n        <div class=\"feature-icon\">&#9670;</div>\n        <h3>Regulatory change monitoring and alerts</h3>\n      </div>\n\n      <div class=\"feature-card\">\n        <div class=\"feature-icon\">&#9670;</div>\n        <h3>Automated reporting and filing</h3>\n      </div>\n\n      <div class=\"feature-card\">\n        <div class=\"feature-icon\">&#9670;</div>\n        <h3>Real-time compliance violation detection</h3>\n      </div>\n\n      <div class=\"feature-card\">\n        <div class=\"feature-icon\">&#9670;</div>\n        <h3>Personalized compliance dashboards</h3>\n      </div>\n        </div>\n      </div>\n    </section>\n  </main>\n  <footer>\n    <div class=\"container\">\n      <p>&copy; 2026 ComplianceAI. All rights reserved.</p>\n    </div>\n  </footer>\n</body>\n</html>"
