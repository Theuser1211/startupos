 p { font-size: 0.95rem; color: #666; }\n    footer { padding: 32px 0; text-align: center; background: var(--primary); color: white; }\n    @media (max-width: 768px) {\n      .page-hero h1 { font-size: 1.8rem; }\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div class=\"container\">\n      <nav>\n        <div class=\"logo\">AI <span>Lawyer</span></div>\n      </nav>\n    </div>\n  </header>\n  <main>\n    <section class=\"page-hero\">\n      <div class=\"container\">\n        <h1>About AI Lawyer</h1>\n        <p>We help startups with legal compliance by making expert legal help accessible and affordable through artificial intelligence.</p>\n      </div>\n    </section>\n    <section class=\"content\">\n      <div class=\"container\">\n        <h2>Our Mission</h2>\n        <p>AI Lawyer was founded with a simple belief: every startup deserves access to quality legal guidance. Traditional legal services are expensive, slow, and inaccessible for early-stage companies. We're changing that with AI.</p>\n        <p>Our platform combines advanced natural language processing with legal expertise to provide instant, accurate legal analysis that would otherwise cost thousands of dollars in lawyer fees.</p>\n        <div class=\"mission-grid\">\n          <div class=\"mission-card\">\n            <h3>Accessibility</h3>\n            <p>Legal help should be available to everyone, not just those who can afford expensive law firms.</p>\n          </div>\n          <div class=\"mission-card\">\n            <h3>Accuracy</h3>\n            <p>Our AI is trained on thousands of legal documents and continuously improved for maximum accuracy.</p>\n          </div>\n          <div class=\"mission-card\">\n            <h3>Speed</h3>\n            <p>Get legal analysis in minutes, not days. Make faster, more informed decisions for your startup.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n  </main>\n  <footer>\n    <div class=\"container\">\n      <p>&copy; 2026 AI Lawyer. All rights reserved.</p>\n    </div>\n  </footer>\n</body>\n</html>"
